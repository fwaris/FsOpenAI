<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="SimpleCrypt.fs" />
    <Compile Include="Model.fs" />
    <Compile Include="Chats.fs" />
    <Compile Include="Update.fs" />
    <Compile Include="Views\ChatParametersView.fs" />
    <Compile Include="Views\SysPromptView.fs" />
    <Compile Include="Views\PromptView.fs" />
    <Compile Include="Views\ChatHistoryView.fs" />
    <Compile Include="Views\ChatView.fs" />
    <Compile Include="AppBar\AppSettingsView.fs" />
    <Compile Include="AppBar\AppBar.fs" />
    <Compile Include="MainLayout.fs" />
    <Compile Include="App.fs" />
    <Compile Include="Startup.fs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Bolero" Version="0.*" />
    <PackageReference Include="Bolero.Build" Version="0.*" />
    <PackageReference Include="Bolero.HotReload" Version="0.*" />
    <PackageReference Include="FSharp.Control.AsyncSeq" Version="3.2.1" />
	<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="7.0.*" />
	<PackageReference Include="MudBlazor" Version="6.4.1" />
	<PackageReference Include="OpenAI" Version="1.7.2" />
	<PackageReference Include="Plotly.Blazor" Version="2.18.2" />
	<PackageReference Include="FSharp.SystemTextJson" Version="1.1.23" />
	<PackageReference Include="System.Threading.Channels" Version="7.0.0" />
  </ItemGroup>
</Project>
